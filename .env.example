# AWS Bedrock Configuration (uses SSO profile-based auth)
# Run: aws sso login --profile <your-profile>
VITE_AWS_REGION=us-west-2
VITE_AWS_PROFILE=PowerUserAccess-361769573044

# Bedrock Models (Claude for text/planning)
VITE_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ─── Image Generation Provider ───────────────────────────────────
# Options: "gemini" | "bedrock"
VITE_IMAGE_PROVIDER=gemini

# ── Gemini Native Image Generation (via Vertex AI) ───────────────
# Uses Application Default Credentials — no API key needed
# Auth: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=/path/to/application_default_credentials.json
VITE_GCP_PROJECT=your-gcp-project-id
VITE_GCP_LOCATION=global
# Models: gemini-3.1-flash-image-preview, gemini-3-pro-image-preview
VITE_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# ── Bedrock Image (fallback) ────────────────────────────────────
# Used when VITE_IMAGE_PROVIDER=bedrock
VITE_BEDROCK_IMAGE_MODEL_ID=stability.sd3-5-large-v1:0
VITE_BEDROCK_IMAGE_REGION=us-west-2
